# ================================================================
# DataVault AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# ================================================================

# --- Hedera (testnet by default) ---
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_PRIVATE_KEY=your_ed25519_private_key_here
HEDERA_NETWORK=testnet

# --- AI APIs ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-openai-key

# --- WalletConnect / Reown ---
NEXT_PUBLIC_HASHCONNECT_PROJECT_ID=your_walletconnect_project_id

# --- DApp Metadata (optional) ---
NEXT_PUBLIC_APP_NAME=DataVault AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=Pay-per-use AI agent on Hedera with x402 micropayments
NEXT_PUBLIC_APP_ICON_URL=
